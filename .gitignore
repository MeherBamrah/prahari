name=.gitignore
# Dependencies
node_modules/
.expo/
dist/
build/

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Native builds
android/.gradle/
android/local.properties
android/**/build/
ios/Pods/
ios/Podfile.lock
ios/Flutter/Flutter.podspec

# TFLite model (download separately - see docs)
assets/models/*.tflite
!assets/models/.gitkeep

# Testing
*.lcov
.nyc_output/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
